{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchPackageNames": ["@rn-primitives/**"],
      "groupName": "rn-primitives monorepo"
    },
    {
      "matchSourceUrls": ["https://github.com/vercel/ai"],
      "groupName": "vercel ai-sdk monorepo"
    }
  ]
}
