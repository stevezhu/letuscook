{
  "name": "assistant-convex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#convex/*": "./convex/*",
    "#*": "./src/*"
  },
  "exports": {
    "./convex/_generated/*": {
      "types": "./convex/_generated/*.d.ts",
      "import": "./convex/_generated/*.js",
      "default": "./convex/_generated/*.js"
    }
  },
  "scripts": {
    "codegen": "is-ci || convex codegen",
    "dev": "convex dev",
    "setup": "convex dev --until-success",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.54",
    "@ai-sdk/openai": "^3.0.49",
    "@convex-dev/workos-authkit": "^0.1.7",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "ai": "^6.0.142",
    "convex": "^1.34.1",
    "convex-helpers": "^0.1.114"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@types/node": "catalog:",
    "convex-test": "^0.0.46",
    "is-ci": "^4.1.0",
    "type-fest": "^5.5.0",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
