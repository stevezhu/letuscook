{
  "include": ["*.config.ts"],
  "compilerOptions": {
    "strict": false,
    "module": "node20",
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "allowJs": true,
    "maxNodeModuleJsDepth": 1,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "composite": true,
    "skipLibCheck": true
  }
}
