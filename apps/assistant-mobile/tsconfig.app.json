{
  "extends": "expo/tsconfig.base.json",
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "*.gen.d.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "uniwind-types.d.ts"
  ],
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "bundler",
    "paths": { "#*": ["./src/*"] },
    "isolatedModules": true,
    "composite": true
  }
}
