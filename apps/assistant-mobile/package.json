{
  "name": "assistant-mobile",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "imports": {
    "#assets/*": "./assets/*",
    "#*": "./src/*"
  },
  "scripts": {
    "android": "expo run:android",
    "dev": "expo start",
    "ios": "expo run:ios",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "expo start",
    "test": "jest",
    "typecheck": "pnpm run --reporter=append-only '/^(typecheck:app|typecheck:metro)$/'",
    "typecheck:app": "tsc --noEmit",
    "typecheck:metro": "tsc --noEmit -p tsconfig.metro.json --composite false",
    "web": "expo start --web"
  },
  "dependencies": {
    "@convex-dev/react-query": "^0.1.0",
