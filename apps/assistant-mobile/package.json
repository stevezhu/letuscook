{
  "name": "assistant-mobile",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "imports": {
    "#assets/*": "./assets/*",
    "#.rnstorybook/*": "./.rnstorybook/*",
    "#*": "./src/*"
  },
  "scripts": {
    "android": "expo run:android",
    "dev": "expo start",
    "ios": "expo run:ios",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "expo start",
    "storybook": "EXPO_PUBLIC_STORYBOOK_ENABLED='true' expo start",
    "storybook:android": "EXPO_PUBLIC_STORYBOOK_ENABLED='true' expo start --android",
    "storybook:generate": "sb-rn-get-stories",
    "storybook:ios": "EXPO_PUBLIC_STORYBOOK_ENABLED='true' expo start --ios",
    "test": "jest",
    "typecheck": "pnpm run --reporter=append-only '/^(typecheck:app|typecheck:metro)$/'",
    "typecheck:app": "tsc --noEmit",
    "typecheck:metro": "tsc --noEmit -p tsconfig.metro.json --composite false",
    "web": "expo start --web"
  },
