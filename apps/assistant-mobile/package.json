    "expo-image": "~55.0.6",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.6",
    "expo-secure-store": "^55.0.9",
    "expo-splash-screen": "~55.0.11",
    "expo-standard-web-crypto": "^55.0.6",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.10",
    "expo-updates": "~55.0.14",
    "expo-web-browser": "~55.0.10",
    "lucide-react-native": "^0.577.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
