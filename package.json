{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "codegen": "turbo run codegen",
    "deps:clean": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "deps:reset": "rm pnpm-lock.yaml && pnpm -w run deps:clean && pnpm install",
    "dev": "turbo run dev",
    "format": "oxfmt && prettier -w '**/{ts,js}config{,.?*}.json'",
    "format:check": "oxfmt --check && prettier -c '**/{ts,js}config{,.?*}.json'",
    "init": "turbo run init",
    "lint": "turbo run format:check lint:oxc lint",
    "lint:fix": "turbo run format && turbo run lint:oxc:fix && turbo run lint:fix",
    "lint:oxc": "oxlint --type-aware",
    "lint:oxc:fix": "oxlint --type-aware --fix",
    "rulesync:install": "GITHUB_TOKEN=$(gh auth token) rulesync install",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@stzhu/prettier-plugin-tsconfig": "catalog:",
    "@types/node": "catalog:",
    "concurrently": "^9.2.1",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.16.0",
    "prettier": "^3.8.1",
    "rulesync": "^7.20.0",
    "syncpack": "^14.2.0",
    "turbo": "^2.8.17"
  },
  "engines": {
    "node": ">=25",
    "pnpm": "^10.0.0"
  },
  "packageManager": "pnpm@10.30.2"
}
