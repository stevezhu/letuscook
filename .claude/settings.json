{
  "permissions": {
    "deny": [
      "Read(!**/.gemini/)",
      "Read(!*.log)",
      "Read(!mdrip)",
      "Read(credentials/)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code needs your attention\" with title \"Claude Code\" sound name \"Glass\"'",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "plansDirectory": "docs/plans"
}
