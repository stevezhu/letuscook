{
  "permissions": {
    "deny": [
      "Read(!**/.gemini/)",
      "Read(!*.log)",
      "Read(!mdrip)",
      "Read(credentials/)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": ["~/.proto"]
    }
  },
  "plansDirectory": "docs/plans",
  "enabledPlugins": {
    "safety-net@cc-marketplace": true
  }
}
