{
  "permissions": {
    "deny": [
      "Read(!**/.gemini/)",
      "Read(!*.log)",
      "Read(!mdrip)",
      "Read(credentials/)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": ["~/.proto"]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/guard-destructive.sh",
            "statusMessage": "Checking for destructive commands..."
          }
        ]
      }
    ]
  },
  "plansDirectory": "docs/plans"
}
