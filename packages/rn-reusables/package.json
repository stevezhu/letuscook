  "private": true,
  "type": "module",
  "exports": {
    "./main.css": "./src/main.css",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "lint": "eslint .",
