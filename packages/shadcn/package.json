    "@types/react": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-oxlint": "^1.60.0",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "tailwindcss": "catalog:"
  }
