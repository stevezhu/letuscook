{
  "name": "@workspace/shadcn",
  "private": true,
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    "./main.css": "./src/main.css",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts",
    "./variants/*": "./src/variants/*.ts"
  },
  "scripts": {
    "lint": "eslint .",
    "shadcn:add-all": "pnpm dlx shadcn@latest add --all --overwrite",
